<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MicaForEveryone.App.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedVisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MicaForEveryone.App.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MicaForEveryone.Models"
    xmlns:nav="using:MicaForEveryone.App.Controls.Navigation"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="48" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <local:SettingsNavigationItemSelector x:Key="NavigationItemSelector">
                <local:SettingsNavigationItemSelector.GlobalRuleTemplate>
                    <DataTemplate>
                        <nav:NavigationViewItem x:Uid="GlobalRuleNavigationViewItem">
                            <nav:NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xED35;" />
                            </nav:NavigationViewItem.Icon>
                        </nav:NavigationViewItem>
                    </DataTemplate>
                </local:SettingsNavigationItemSelector.GlobalRuleTemplate>
                <local:SettingsNavigationItemSelector.ProcessRuleTemplate>
                    <DataTemplate x:DataType="models:ProcessRule">
                        <nav:NavigationViewItem Content="{x:Bind ProcessName}">
                            <nav:NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xECAA;" />
                            </nav:NavigationViewItem.Icon>
                        </nav:NavigationViewItem>
                    </DataTemplate>
                </local:SettingsNavigationItemSelector.ProcessRuleTemplate>
                <local:SettingsNavigationItemSelector.ClassRuleTemplate>
                    <DataTemplate x:DataType="models:ClassRule">
                        <nav:NavigationViewItem Content="{x:Bind ClassName}">
                            <nav:NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE737;" />
                            </nav:NavigationViewItem.Icon>
                        </nav:NavigationViewItem>
                    </DataTemplate>
                </local:SettingsNavigationItemSelector.ClassRuleTemplate>
            </local:SettingsNavigationItemSelector>
            <x:Double x:Key="SettingsCardWrapThreshold">0</x:Double>
        </Grid.Resources>

        <TitleBar
            x:Name="TitleBarControl"
            x:Uid="TitleBarControl"
            VerticalAlignment="Stretch"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBarControl_PaneToggleRequested">
            <TitleBar.IconSource>
                <BitmapIconSource ShowAsMonochrome="False" UriSource="ms-appx:///Assets/Square44x44Logo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <nav:NavigationView
            x:Name="NavigationViewControl"
            Grid.Row="1"
            MenuItemTemplateSelector="{StaticResource NavigationItemSelector}"
            MenuItemsSource="{x:Bind ViewModel.SettingsService.Settings.Rules, Mode=OneWay}"
            SelectionChanged="RuleListView_SelectionChanged">
            <nav:NavigationView.FooterMenuItems>
                <nav:NavigationViewItem
                    x:Name="AddNewRuleItem"
                    Content="Add new rule"
                    Icon="Add"
                    SelectsOnInvoked="False">
                    <nav:NavigationViewItem.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Uid="AddProcessRuleMenuFlyoutItem" Click="AddProcessRuleMenuFlyoutItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xECAA;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="AddClassRuleMenuFlyoutItem" Click="AddClassRuleMenuFlyoutItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE737;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </nav:NavigationViewItem.Flyout>
                </nav:NavigationViewItem>
                <nav:NavigationViewItem Content="Settings">
                    <nav:NavigationViewItem.Icon>
                        <AnimatedIcon>
                            <animatedVisuals:AnimatedSettingsVisualSource />
                        </AnimatedIcon>
                    </nav:NavigationViewItem.Icon>
                </nav:NavigationViewItem>
            </nav:NavigationView.FooterMenuItems>
            <Frame x:Name="_contentFrame" Navigated="_contentFrame_Navigated" />
        </nav:NavigationView>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="TitleBarInactivated">
                    <VisualState.Setters>
                        <Setter Target="CaptionTextBlock.Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="TitleBarActive">
                    <VisualState.Setters>
                        <Setter Target="CaptionTextBlock.Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
            <VisualStateGroup>
                <VisualState>
                    <VisualState.Setters>
                        <Setter Target="NavigationViewControl.DisplayMode" Value="Inline" />
                        <Setter Target="TitleBarControl.IsPaneToggleButtonVisible" Value="False" />
                        <Setter Target="NavigationViewControl.IsPaneOpen" Value="True" />
                        <Setter Target="TitleBarRow.Height" Value="32" />
                        <Setter Target="_contentFrame.Margin" Value="0" />
                        <Setter Target="NavigationViewControl.PaneBackground" Value="{ThemeResource NavigationViewExpandedPaneBackground}" />
                        <Setter Target="NavigationViewControl.BorderBrush" Value="Transparent" />
                    </VisualState.Setters>
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="700" />
                    </VisualState.StateTriggers>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</Page>
